  "weekStart": "",
  "alerts": [
    {
      "name": "P99 Latency SLO Breach",
      "condition": "A",
      "data": [
        {
          "refId": "A",
          "queryType": "",
          "datasourceUid": "prometheus",
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          },
          "model": {
            "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m]))) > 0.2",
            "interval": "",
            "legendFormat": "",
            "refId": "A"
          }
        }
      ],
      "noDataState": "NoData",
      "execErrState": "Alerting",
      "for": "5m",
      "annotations": {
        "description": "HTTP request P99 latency exceeded 200ms for 5 minutes (SLO breach).",
        "summary": "High latency alert: P99 > 200ms"
      },
      "labels": {
        "severity": "warning",
        "service": "stoat-and-ferret"
      }
    },
    {
      "name": "Error Budget Exceeded",
      "condition": "A",
      "data": [
        {
          "refId": "A",
          "queryType": "",
          "datasourceUid": "prometheus",
          "relativeTimeRange": {
            "from": 600,
            "to": 0
          },
          "model": {
            "expr": "(sum(rate(http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 1)) > 0.01",
            "interval": "",
            "legendFormat": "",
            "refId": "A"
          }
        }
      ],
      "noDataState": "NoData",
      "execErrState": "Alerting",
      "for": "5m",
      "annotations": {
        "description": "5xx error rate exceeded 1% for 5 minutes (error budget burn).",
        "summary": "Error budget alert: error rate > 1%"
      },
      "labels": {
        "severity": "warning",
        "service": "stoat-and-ferret"
      }
    }
  ]
